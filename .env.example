# ============================================================
# DocuMind — environment configuration
# Copy to .env and edit secrets before deploying.
# ============================================================

# ---- PostgreSQL (with pgvector) ----
POSTGRES_DB=documind
POSTGRES_USER=documind
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- Auth / JWT ----
SECRET_KEY=change-this-to-a-random-64-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Ollama ----
OLLAMA_HOST=http://ollama:11434

# ---- Chat / text LLM ----
LLM_MODEL=gemma3:27b
LLM_FALLBACK_MODEL=gemma3:12b
LLM_CTX_TOKENS=32768
LLM_MAX_NEW_TOKENS=2048

# ---- Vision model (VLM) ----
# The VLM is fully generic and decoupled from the chat LLM.
# Set it to ANY multimodal model available in your Ollama instance
# (e.g. gemma3:27b, llava:13b, llama3.2-vision:11b, qwen2.5vl:7b, ...).
# Toggle VLM_ENABLED=false to disable vision entirely and fall back
# to Tesseract OCR for scanned pages / skip figure descriptions.
VLM_ENABLED=true
VLM_MODEL=llava:13b
VLM_MAX_NEW_TOKENS=1024

# ---- Embeddings ----
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768

# ---- Storage ----
UPLOAD_DIR=/app/uploads
IMAGE_DIR=/app/images
MAX_UPLOAD_MB=100

# ---- CORS ----
ALLOWED_ORIGIN=http://localhost

# ---- Celery ----
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- Models to auto-pull on first Ollama start (space separated) ----
# Keep this in sync with LLM_MODEL / VLM_MODEL / EMBEDDING_MODEL.
OLLAMA_PULL_MODELS=gemma3:27b llava:13b nomic-embed-text
